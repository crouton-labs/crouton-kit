#!/usr/bin/env bash
#
# protected-push - Push commits from protected branch via PR
#
# Usage: protected-push [options]
#
# When you have committed changes on a protected branch, this script:
# 1. Creates a new branch with those commits
# 2. Pushes the new branch
# 3. Opens a PR to the protected branch
# 4. Resets the protected branch to match remote (removing local commits)
#
# Options:
#   --auto-merge     Enable GitHub auto-merge and watch CI in background
#   --branch <name>  Specify branch name (default: auto-generated)
#   --title <title>  PR title (default: from first commit message)
#   --dry-run        Show what would be done without making changes
#   -h, --help       Show this help

set -euo pipefail

die() {
    echo "Error: $1" >&2
    exit 1
}

usage() {
    cat <<EOF
Usage: protected-push [options]

Push committed changes from a protected branch via PR workflow.

Options:
  --auto-merge     Enable GitHub auto-merge and watch CI in background
  --branch <name>  Specify branch name (default: auto-generated from commits)
  --title <title>  PR title (default: from first commit message)
  --dry-run        Show what would be done without making changes
  -h, --help       Show this help

What this does:
  1. Detects commits ahead of remote on current (protected) branch
  2. Creates a new feature branch from those commits
  3. Pushes the feature branch to remote
  4. Opens a PR targeting the protected branch
  5. Resets local protected branch to match remote
  6. (Optional) Enables auto-merge and watches CI

Example:
  protected-push                    # Basic usage
  protected-push --auto-merge       # Auto-merge when CI passes
  protected-push --branch my-fix    # Custom branch name
EOF
    exit 0
}

# Parse arguments
AUTO_MERGE=false
BRANCH_NAME=""
PR_TITLE=""
DRY_RUN=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --auto-merge)
            AUTO_MERGE=true
            shift
            ;;
        --branch)
            shift
            [[ $# -eq 0 ]] && die "--branch requires a name argument"
            BRANCH_NAME="$1"
            shift
            ;;
        --title)
            shift
            [[ $# -eq 0 ]] && die "--title requires a title argument"
            PR_TITLE="$1"
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            die "Unknown option: $1"
            ;;
    esac
done

# Must be in a git repo
git rev-parse --git-dir > /dev/null 2>&1 || die "Not in a git repository"

REPO_ROOT="$(git rev-parse --show-toplevel)"
CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"

# Check we have a remote
REMOTE="origin"
if ! git remote get-url "$REMOTE" > /dev/null 2>&1; then
    die "No remote '$REMOTE' configured"
fi

# Get remote URL for GitHub API
REMOTE_URL="$(git remote get-url "$REMOTE")"

# Check if this is a GitHub repo
if [[ ! "$REMOTE_URL" =~ github\.com ]]; then
    die "This script only works with GitHub repositories"
fi

# Parse owner/repo
if [[ "$REMOTE_URL" =~ github\.com[:/]([^/]+)/([^/]+?)(\.git)?$ ]]; then
    OWNER="${BASH_REMATCH[1]}"
    REPO="${BASH_REMATCH[2]}"
else
    die "Could not parse GitHub owner/repo from remote URL"
fi

# Check if branch is protected
check_protected() {
    local branch="$1"
    # Use gh CLI to check branch protection
    if gh api "repos/${OWNER}/${REPO}/branches/${branch}/protection" --silent 2>/dev/null; then
        return 0
    fi
    return 1
}

if ! check_protected "$CURRENT_BRANCH"; then
    die "Branch '$CURRENT_BRANCH' is not protected. Use regular git push."
fi

echo "Protected branch detected: $CURRENT_BRANCH"

# Fetch latest from remote
echo "Fetching latest from $REMOTE..."
git fetch "$REMOTE" "$CURRENT_BRANCH" --quiet

# Check for commits ahead of remote
REMOTE_REF="${REMOTE}/${CURRENT_BRANCH}"
COMMITS_AHEAD=$(git rev-list --count "${REMOTE_REF}..HEAD" 2>/dev/null || echo "0")

if [[ "$COMMITS_AHEAD" -eq 0 ]]; then
    echo "No commits to push. Local branch is up to date with $REMOTE_REF"
    exit 0
fi

echo "Found $COMMITS_AHEAD commit(s) ahead of $REMOTE_REF"

# Get commit info for naming/title
FIRST_COMMIT_MSG="$(git log -1 --format='%s' "${REMOTE_REF}..HEAD" | head -1)"
FIRST_COMMIT_SHORT="$(git log -1 --format='%h' "${REMOTE_REF}..HEAD" | head -1)"

# Generate branch name if not provided
if [[ -z "$BRANCH_NAME" ]]; then
    # Get username from git
    USERNAME=$(git config user.name 2>/dev/null | awk '{print tolower($1)}' || echo "user")
    # Sanitize commit message for branch name
    SLUG=$(echo "$FIRST_COMMIT_MSG" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//' | sed 's/-$//' | cut -c1-40)
    TIMESTAMP=$(date +%Y%m%d-%H%M%S)
    BRANCH_NAME="${USERNAME}/push/${SLUG}-${TIMESTAMP}"
fi

# Use commit message as PR title if not provided
if [[ -z "$PR_TITLE" ]]; then
    PR_TITLE="$FIRST_COMMIT_MSG"
fi

echo ""
echo "Plan:"
echo "  1. Create branch: $BRANCH_NAME"
echo "  2. Push to: $REMOTE"
echo "  3. Create PR: '$PR_TITLE' -> $CURRENT_BRANCH"
echo "  4. Reset local $CURRENT_BRANCH to $REMOTE_REF"
if $AUTO_MERGE; then
    echo "  5. Enable auto-merge and watch CI"
fi
echo ""

if $DRY_RUN; then
    echo "[Dry run - no changes made]"
    exit 0
fi

# Create the new branch at current HEAD
echo "Creating branch '$BRANCH_NAME'..."
git branch "$BRANCH_NAME"

# Push the new branch
echo "Pushing to $REMOTE..."
git push -u "$REMOTE" "$BRANCH_NAME"

# Create the PR
echo "Creating pull request..."
PR_BODY="Automated PR from protected branch push.

**Commits:**
$(git log --oneline "${REMOTE_REF}..HEAD")

---
*Created by \`protected-push\`*"

PR_URL=$(gh pr create \
    --base "$CURRENT_BRANCH" \
    --head "$BRANCH_NAME" \
    --title "$PR_TITLE" \
    --body "$PR_BODY" 2>&1)

echo "PR created: $PR_URL"

# Reset current branch to remote
echo "Resetting local '$CURRENT_BRANCH' to match $REMOTE_REF..."
git reset --hard "$REMOTE_REF"

echo ""
echo "✓ Done!"
echo "  Branch pushed: $BRANCH_NAME"
echo "  PR: $PR_URL"
echo "  Local $CURRENT_BRANCH reset to $REMOTE_REF"

# Handle auto-merge
if $AUTO_MERGE; then
    echo ""
    echo "Enabling auto-merge..."

    # Extract PR number from URL
    PR_NUMBER=$(echo "$PR_URL" | grep -oE '[0-9]+$')

    # Enable auto-merge via gh
    if gh pr merge "$PR_NUMBER" --auto --squash 2>/dev/null; then
        echo "✓ Auto-merge enabled (squash)"
    else
        echo "⚠ Could not enable auto-merge (may require admin permissions)"
        echo "  You can manually enable it: gh pr merge $PR_NUMBER --auto --squash"
    fi

    # Watch CI in background
    echo "Starting CI watcher in background..."

    # Create a background watcher script
    WATCHER_SCRIPT=$(mktemp)
    cat > "$WATCHER_SCRIPT" << 'WATCHER_EOF'
#!/usr/bin/env bash
# CI Watcher for PR auto-merge
PR_NUMBER="$1"
MAX_WAIT=3600  # 1 hour max
POLL_INTERVAL=30
ELAPSED=0

echo "[$(date)] Watching PR #$PR_NUMBER for CI completion..."

while [[ $ELAPSED -lt $MAX_WAIT ]]; do
    # Get PR status
    STATUS=$(gh pr view "$PR_NUMBER" --json state,mergeable,mergeStateStatus 2>/dev/null)

    if [[ -z "$STATUS" ]]; then
        echo "[$(date)] Could not fetch PR status"
        sleep $POLL_INTERVAL
        ELAPSED=$((ELAPSED + POLL_INTERVAL))
        continue
    fi

    STATE=$(echo "$STATUS" | jq -r '.state')
    MERGEABLE=$(echo "$STATUS" | jq -r '.mergeable')
    MERGE_STATE=$(echo "$STATUS" | jq -r '.mergeStateStatus')

    if [[ "$STATE" == "MERGED" ]]; then
        echo "[$(date)] ✓ PR #$PR_NUMBER has been merged!"

        # Notify if terminal-notifier is available
        if command -v terminal-notifier &> /dev/null; then
            terminal-notifier -title "PR Merged" -message "PR #$PR_NUMBER has been merged" -sound default
        elif command -v osascript &> /dev/null; then
            osascript -e "display notification \"PR #$PR_NUMBER has been merged\" with title \"PR Merged\""
        fi
        exit 0
    fi

    if [[ "$STATE" == "CLOSED" ]]; then
        echo "[$(date)] PR #$PR_NUMBER was closed without merging"
        exit 1
    fi

    if [[ "$MERGE_STATE" == "BLOCKED" ]]; then
        # Check if it's blocked due to failing checks
        CHECKS=$(gh pr checks "$PR_NUMBER" --json state,name 2>/dev/null)
        FAILED=$(echo "$CHECKS" | jq '[.[] | select(.state == "FAILURE")] | length')

        if [[ "$FAILED" -gt 0 ]]; then
            echo "[$(date)] ✗ CI checks failed for PR #$PR_NUMBER"
            echo "$CHECKS" | jq '.[] | select(.state == "FAILURE") | .name'

            if command -v terminal-notifier &> /dev/null; then
                terminal-notifier -title "PR CI Failed" -message "PR #$PR_NUMBER has failing checks" -sound Basso
            elif command -v osascript &> /dev/null; then
                osascript -e "display notification \"PR #$PR_NUMBER has failing checks\" with title \"PR CI Failed\""
            fi
            exit 1
        fi
    fi

    echo "[$(date)] Waiting... (state=$STATE, mergeable=$MERGEABLE, mergeState=$MERGE_STATE)"
    sleep $POLL_INTERVAL
    ELAPSED=$((ELAPSED + POLL_INTERVAL))
done

echo "[$(date)] Timeout waiting for PR #$PR_NUMBER"
exit 2
WATCHER_EOF

    chmod +x "$WATCHER_SCRIPT"

    # Run watcher in background, output to log file
    LOG_FILE="/tmp/protected-push-watcher-${PR_NUMBER}.log"
    nohup bash "$WATCHER_SCRIPT" "$PR_NUMBER" > "$LOG_FILE" 2>&1 &
    WATCHER_PID=$!

    echo "✓ CI watcher started (PID: $WATCHER_PID)"
    echo "  Log: $LOG_FILE"
    echo "  To check status: tail -f $LOG_FILE"
    echo "  To stop: kill $WATCHER_PID"
fi
