// src/render.ts
import { spawnSync } from "node:child_process";
import { existsSync as existsSync2, mkdtempSync, readFileSync as readFileSync4, rmSync as rmSync2 } from "node:fs";
import { tmpdir } from "node:os";
import { join } from "node:path";
function resolveClaudeExecutable() {
  const envPath = process.env.CLAUDE_CODE_EXECPATH;
  if (envPath) return envPath;
  const which = spawnSync("command", ["-v", "claude"], {
    encoding: "utf-8",
    shell: true
  });
  const resolved = which.stdout.trim();
  if (resolved) return resolved;
  throw new Error(
    "Cannot locate the Claude Code executable. Set CLAUDE_CODE_EXECPATH or ensure `claude` is on PATH."
  );
}
async function generateVisualization(args) {
  const tmpDir = mkdtempSync(join(tmpdir(), "render-viz-"));
  const tempFile = join(tmpDir, "viz.md");
  const cleanup = () => rmSync2(tmpDir, { recursive: true, force: true });
  const promptWithInstructions = `${args.userPrompt}

====

Your workflow:
1. Write the termrender markdown to: ${tempFile}
2. Validate by running: termrender --check ${tempFile}
3. If validation fails, read the error, fix the markdown, write it again, re-validate.
4. Repeat until \`termrender --check\` exits 0.
5. Respond with the word "done" when the file is valid.`;
  const result2 = Ph({
    prompt: promptWithInstructions,
    options: {
      model: args.config.model,
      systemPrompt: args.config.system_prompt,
      tools: ["Bash", "Write", "Read", "Edit"],
      permissionMode: "bypassPermissions",
      allowDangerouslySkipPermissions: true,
      maxTurns: args.maxTurns,
      pathToClaudeCodeExecutable: resolveClaudeExecutable()
    }
  });
  let errored = false;
  const errors = [];
  for await (const message of result2) {
    if (message.type === "result") {
      if (message.subtype !== "success") {
        errored = true;
        if ("errors" in message && Array.isArray(message.errors)) {
          errors.push(...message.errors.map(String));
        } else {
          errors.push(message.subtype);
        }
      }
    }
  }
  if (errored) {
    cleanup();
    throw new Error(`Claude query failed: ${errors.join(", ")}`);
  }
  if (!existsSync2(tempFile)) {
    cleanup();
    throw new Error(`Haiku did not write the expected output file: ${tempFile}`);
  }
  const check2 = spawnSync("termrender", ["--check", tempFile], { encoding: "utf-8" });
  if (check2.status !== 0) {
    const errText = check2.stderr.length > 0 ? check2.stderr : check2.stdout;
    const markdown2 = readFileSync4(tempFile, "utf-8");
    cleanup();
    throw new Error(
      `Final validation failed: ${errText.trim()}

Generated markdown:
${markdown2}`
    );
  }
  const markdown = readFileSync4(tempFile, "utf-8");
  return { markdown, tempFile, cleanup };
}

// src/cli.ts
var { values } = parseArgs({
  options: {
    context: { type: "string", default: "transcript" },
    transcript: { type: "string" },
    file: { type: "string" },
    builtin: { type: "string" },
    config: { type: "string" },
    model: { type: "string" },
    "max-turns": { type: "string", default: "10" },
    "dry-run": { type: "boolean", default: false },
    help: { type: "boolean", short: "h", default: false }
  },
  strict: true
});
if (values.help) {
  printHelp();
  process.exit(0);
}
var source = values.context;
if (!["transcript", "last-message", "stdin", "file"].includes(source)) {
  console.error(`Error: invalid --context value: ${source}`);
  process.exit(1);
}
if (values.builtin && values.config) {
  console.error("Error: --builtin and --config are mutually exclusive");
  process.exit(1);
}
if (!values.builtin && !values.config) {
  console.error("Error: either --builtin or --config is required");
  process.exit(1);
}
var maxTurns = parseInt(values["max-turns"], 10);
if (!Number.isFinite(maxTurns) || maxTurns < 1) {
  console.error(`Error: invalid --max-turns: ${values["max-turns"]}`);
  process.exit(1);
}
var config2 = values.builtin ? loadBuiltin(values.builtin) : loadConfigFile(values.config);
if (values.model) {
  config2.model = values.model;
}
var context = await gatherContext({
  source,
  transcriptPath: values.transcript,
  filePath: values.file,
  maxMessages: config2.max_messages,
  maxChars: config2.max_chars
});
var userPrompt = config2.prompt.replace("{{context}}", context);
var result = await generateVisualization({
  config: config2,
  userPrompt,
  maxTurns
});
if (values["dry-run"]) {
  process.stdout.write(result.markdown + "\n");
  result.cleanup();
  process.exit(0);
}
var child = spawn("termrender", ["--tmux", result.tempFile], {
  stdio: "inherit",
  detached: false
});
child.on("exit", (code) => {
  setTimeout(() => result.cleanup(), 5e3).unref();
  process.exit(code ?? 0);
});
function printHelp() {
  console.log(`render-viz - Generate and display termrender visualizations

Usage:
  render-viz --builtin <name> --transcript <path>
  render-viz --config <path> --context stdin < input.md
  render-viz --config <path> --context file --file <path>

Options:
  --context <source>     transcript | last-message | stdin | file (default: transcript)
  --transcript <path>    Claude transcript JSONL (for transcript/last-message)
  --file <path>          File to read as context (for context=file)
  --builtin <name>       Use a builtin config: ${listBuiltins().join(", ")}
  --config <path>        Path to a YAML config file
  --model <id>           Override config model
  --max-turns <n>        Max agentic turns for Haiku's self-correction (default: 10)
  --dry-run              Print markdown to stdout instead of opening tmux pane
  -h, --help             Show this help`);
}
