// src/context.ts
import { readFileSync as readFileSync2 } from "node:fs";
async function gatherContext(opts) {
  switch (opts.source) {
    case "transcript":
      return fromTranscript(requireTranscript(opts), opts.maxMessages, opts.maxChars);
    case "last-message":
      return lastAssistantMessage(requireTranscript(opts), opts.maxChars);
    case "stdin":
      return truncate(await readStdin(), opts.maxChars);
    case "file":
      if (!opts.filePath) {
        throw new Error("--file <path> is required when --context=file");
      }
      return truncate(readFileSync2(opts.filePath, "utf-8"), opts.maxChars);
  }
}
function requireTranscript(opts) {
  if (!opts.transcriptPath) {
    throw new Error(`--transcript <path> is required when --context=${opts.source}`);
  }
  return opts.transcriptPath;
}
function isTextBlock(block) {
  return typeof block === "object" && block !== null && block.type === "text" && typeof block.text === "string";
}
function extractText(content) {
  if (typeof content === "string") return content;
  if (!Array.isArray(content)) return "";
  return content.filter(isTextBlock).map((block) => block.text).join("\n").trim();
}
function parseTranscript(path) {
  const raw = readFileSync2(path, "utf-8");
  const entries = [];
  for (const line of raw.split("\n")) {
    const trimmed = line.trim();
    if (!trimmed) continue;
    const parsed = JSON.parse(trimmed);
    entries.push(parsed);
  }
  return entries;
}
function fromTranscript(path, maxMessages, maxChars) {
  const entries = parseTranscript(path);
  const messages = [];
  for (const entry of entries) {
    if (entry.type !== "user" && entry.type !== "assistant") continue;
    const text = extractText(entry.message?.content);
    if (!text) continue;
    messages.push({ role: entry.type.toUpperCase(), text });
  }
  const recent = messages.slice(-maxMessages);
  const formatted = recent.map((m2) => `${m2.role}:
${m2.text}`).join("\n\n---\n\n");
  return truncate(formatted, maxChars);
}
function lastAssistantMessage(path, maxChars) {
  const entries = parseTranscript(path);
  for (let i2 = entries.length - 1; i2 >= 0; i2--) {
    const entry = entries[i2];
    if (entry.type !== "assistant") continue;
    const text = extractText(entry.message?.content);
    if (text) return truncate(text, maxChars);
  }
  throw new Error(`No assistant message found in transcript: ${path}`);
}
function truncate(text, maxChars) {
  if (text.length <= maxChars) return text;
  return "[...truncated...]\n\n" + text.slice(-maxChars);
}
async function readStdin() {
  const chunks = [];
  for await (const chunk of process.stdin) {
    chunks.push(chunk);
  }
  return Buffer.concat(chunks).toString("utf-8");
}

