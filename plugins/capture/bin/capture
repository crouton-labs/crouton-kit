// src/capture.ts
var fs4 = __toESM(require("fs"));
var path4 = __toESM(require("path"));
var os3 = __toESM(require("os"));
var import_child_process2 = require("child_process");
init_har_manager();
init_cdp();
init_session_context();
var CAPTURE_ROOT2 = path4.join(os3.tmpdir(), "capture-sessions");
function sessionDir(id) {
  return path4.join(CAPTURE_ROOT2, id);
}
function sessionMetaPath(id) {
  return path4.join(sessionDir(id), ".session.json");
}
function readSession(id) {
  const metaPath = sessionMetaPath(id);
  if (!fs4.existsSync(metaPath)) {
    throw new Error(`No capture session found: ${id}`);
  }
  return JSON.parse(fs4.readFileSync(metaPath, "utf-8"));
}
function generateId() {
  return `cap-${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 6)}`;
}
async function start(args) {
  let url = null;
  for (let i = 0; i < args.length; i++) {
    if (args[i] === "--url" && args[i + 1]) {
      url = args[++i];
    }
  }
  const id = generateId();
  const dir = sessionDir(id);
  fs4.mkdirSync(path4.join(dir, "shots"), { recursive: true });
  fs4.mkdirSync(path4.join(dir, "a11y"), { recursive: true });
  let harId = null;
  try {
    const harResult = createHarRecording();
    harId = harResult.id;
  } catch (err) {
    console.error(`Warning: could not start HAR recording: ${err instanceof Error ? err.message : err}`);
  }
  let targetId = null;
  if (url) {
    try {
      const { detectCdpPort: detectCdpPort2, navigateAndWait: navigateAndWait2 } = await Promise.resolve().then(() => (init_cdp(), cdp_exports));
      const port = await detectCdpPort2();
      const tab = await navigateAndWait2(port, url);
      targetId = tab.id;
    } catch (err) {
      console.error(`Warning: could not open tab: ${err instanceof Error ? err.message : err}`);
    }
  }
  const session = {
    id,
    dir,
    harId,
    startedAt: (/* @__PURE__ */ new Date()).toISOString(),
    url,
    targetId,
    stepCount: 0,
    logPids: []
  };
  fs4.writeFileSync(sessionMetaPath(id), JSON.stringify(session, null, 2));
  setActiveSession({
    sessionId: id,
    dir,
    harId,
    targetId,
    stepCount: 0
  });
  const result = {
    sessionId: id,
    bundleDir: dir,
    harId,
    targetId,
    shotsDir: path4.join(dir, "shots"),
    a11yDir: path4.join(dir, "a11y")
  };
  console.log(JSON.stringify(result, null, 2));
  console.error(`
Capture session started: ${id}`);
  if (targetId) {
    console.error(`Tab opened \u2014 session context active. No need to pass --target or --har.`);
  }
  console.error(`
When done: capture session stop ${id}`);
}
function logCommand(args) {
  const sourcePath = args[0];
  if (!sourcePath) {
    console.error("Usage: capture log <path> [--name label] [--session <id>]");
    process.exit(1);
  }
  const resolved = path4.resolve(sourcePath);
  if (!fs4.existsSync(resolved)) {
    throw new Error(`Log file not found: ${resolved}`);
  }
  let name = null;
  let sessionId = null;
  for (let i = 1; i < args.length; i++) {
    if (args[i] === "--name" && args[i + 1]) name = args[++i];
    if (args[i] === "--session" && args[i + 1]) sessionId = args[++i];
  }
  if (!sessionId) {
    const active = getActiveSession();
    if (!active) {
      throw new Error("No active capture session. Start one or pass --session <id>.");
    }
    sessionId = active.sessionId;
  }
  const session = readSession(sessionId);
  name = name ?? path4.basename(resolved, path4.extname(resolved));
  const logsDir = path4.join(session.dir, "logs");
  fs4.mkdirSync(logsDir, { recursive: true });
  const destPath = path4.join(logsDir, `${name}.log`);
  const outFd = fs4.openSync(destPath, "a");
  const child = (0, import_child_process2.spawn)(
    "sh",
    ["-c", `tail -f "${resolved}" | perl -MPOSIX -ne 'print strftime("%Y-%m-%dT%H:%M:%SZ",gmtime())." ".$_'`],
    { detached: true, stdio: ["ignore", outFd, "ignore"] }
  );
  child.unref();
  fs4.closeSync(outFd);
  const pid = child.pid;
  session.logPids.push({ pid, name, sourcePath: resolved });
  fs4.writeFileSync(sessionMetaPath(session.id), JSON.stringify(session, null, 2));
  console.log(JSON.stringify({ name, sourcePath: resolved, destPath, pid }, null, 2));
}
async function stop(args) {
  const id = args[0];
  if (!id) {
    console.error("Usage: capture session stop <session-id>");
    process.exit(1);
  }
  const session = readSession(id);
  const stoppedAt = (/* @__PURE__ */ new Date()).toISOString();
  const startMs = new Date(session.startedAt).getTime();
  const duration = Date.now() - startMs;
  for (const lp of session.logPids ?? []) {
    try {
      process.kill(-lp.pid, "SIGTERM");
    } catch {
    }
  }
  if (session.logPids?.length) {
    await new Promise((r) => setTimeout(r, 200));
  }
  const shotsDir = path4.join(session.dir, "shots");
  const screenshots = fs4.existsSync(shotsDir) ? fs4.readdirSync(shotsDir).filter((f) => f.endsWith(".png") || f.endsWith(".jpg")).map((f) => ({ name: f, path: path4.join(shotsDir, f) })) : [];
  const a11yDir = path4.join(session.dir, "a11y");
  const a11y = fs4.existsSync(a11yDir) ? fs4.readdirSync(a11yDir).filter((f) => f.endsWith(".json") || f.endsWith(".txt")).map((f) => ({ name: f, path: path4.join(a11yDir, f) })) : [];
  let har = null;
  if (session.harId) {
    try {
      const harData = readHarRecording(session.harId);
      if (harData) {
        const harPath = path4.join(session.dir, "har.json");
        fs4.writeFileSync(harPath, JSON.stringify(harData, null, 2));
        har = { id: session.harId, path: harPath, entryCount: harData.log.entries.length };
        try {
          deleteHarRecording(session.harId);
        } catch {
        }
      }
    } catch (err) {
      console.error(`Warning: could not read HAR: ${err instanceof Error ? err.message : err}`);
    }
  }
  const logsDir = path4.join(session.dir, "logs");
  const logs = fs4.existsSync(logsDir) ? fs4.readdirSync(logsDir).filter((f) => f.endsWith(".log")).map((f) => {
    const filePath = path4.join(logsDir, f);
    const content = fs4.readFileSync(filePath, "utf-8");
    const lines = content ? content.split("\n").filter(Boolean).length : 0;
    return { name: f, path: filePath, lines };
  }) : [];
  const knownDirs = /* @__PURE__ */ new Set(["shots", "a11y", "logs"]);
  const knownFiles = /* @__PURE__ */ new Set([".session.json", "har.json", "bundle.json"]);
  const other = fs4.readdirSync(session.dir).filter((f) => !knownDirs.has(f) && !knownFiles.has(f)).map((f) => ({ name: f, path: path4.join(session.dir, f) }));
  clearActiveSession();
  const manifest = {
    id: session.id,
    startedAt: session.startedAt,
    stoppedAt,
    duration,
    url: session.url,
    screenshots,
    har,
    a11y,
    logs,
    other
  };
  const bundlePath = path4.join(session.dir, "bundle.json");
  fs4.writeFileSync(bundlePath, JSON.stringify(manifest, null, 2));
  console.log(JSON.stringify({
    bundlePath,
    summary: {
      duration,
      screenshots: screenshots.length,
      harEntries: har?.entryCount ?? 0,
      a11ySnapshots: a11y.length,
      logFiles: logs.length,
      otherFiles: other.length
    }
  }, null, 2));
  console.error(`
Bundle written: ${bundlePath}`);
  console.error(`Read it: capture session view ${id}`);
}
function list() {
  if (!fs4.existsSync(CAPTURE_ROOT2)) {
    console.log("[]");
    return;
  }
  const sessions = fs4.readdirSync(CAPTURE_ROOT2).filter((d) => fs4.existsSync(sessionMetaPath(d))).map((d) => {
    const session = readSession(d);
    const hasBundled = fs4.existsSync(path4.join(session.dir, "bundle.json"));
    return { id: session.id, startedAt: session.startedAt, url: session.url, status: hasBundled ? "stopped" : "active" };
  });
  console.log(JSON.stringify(sessions, null, 2));
}
function view(args) {
  const id = args[0];
  if (!id) {
    console.error("Usage: capture session view <session-id> [--filter screenshots|har|a11y]");
    process.exit(1);
  }
  const session = readSession(id);
  const bundlePath = path4.join(session.dir, "bundle.json");
  if (!fs4.existsSync(bundlePath)) {
    console.error(`Session ${id} hasn't been stopped yet. Run: capture session stop ${id}`);
    process.exit(1);
  }
  const manifest = JSON.parse(fs4.readFileSync(bundlePath, "utf-8"));
  const filter = args.find((_, i) => args[i - 1] === "--filter");
  if (filter) {
    const section = manifest[filter];
    console.log(JSON.stringify(section, null, 2));
  } else {
    console.log(JSON.stringify(manifest, null, 2));
  }
}
async function sessionMain(args) {
  const [subcommand, ...rest] = args;
  switch (subcommand) {
    case "start":
      return start(rest);
    case "stop":
      return stop(rest);
    case "list":
      return list();
    case "view":
      return view(rest);
    default:
      console.log(`capture session \u2014 manage capture sessions

Commands:
  start [--url <url>]                Start a capture session
  stop <session-id>                  Finalize and bundle all artifacts
  list                               List active and stopped sessions
  view <id> [--filter section]       View bundle manifest
  log <path> [--name label]          Tail a log file into the session

Workflow:
  1. capture session start --url http://localhost:3000
  2. Use CDP commands directly:
       capture screenshot --url localhost --out $CAPTURE_DIR/shots/homepage.png --har $HAR_ID
       capture exec "document.querySelector('.btn').click()" --url localhost --har $HAR_ID
       capture a11y --url localhost --json > $CAPTURE_DIR/a11y/after-login.json
  3. capture session stop <session-id>
  4. capture session view <session-id>`);
  }
}
